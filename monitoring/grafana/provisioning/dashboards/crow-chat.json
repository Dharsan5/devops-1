{
  "id": null,
  "uid": "crow-chat-overview",
  "title": "Crow Chat — Overview",
  "tags": ["crow-chat"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Active WebSocket Connections",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1a1a2e", "value": null },
              { "color": "#ff6b35",  "value": 1 },
              { "color": "#ff6b35",  "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crow_socket_active_connections",
          "legendFormat": "connections"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total Messages Sent",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1a1a2e", "value": null },
              { "color": "#ff6b35",  "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crow_chat_messages_total",
          "legendFormat": "messages"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1a1a2e", "value": null },
              { "color": "#ff6b35",  "value": 0.1 }
            ]
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(crow_http_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Message Error Rate",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1a1a2e", "value": null },
              { "color": "#f6c90e",  "value": 0.01 },
              { "color": "#e84855",  "value": 0.1 }
            ]
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(crow_chat_message_errors_total[1m])",
          "legendFormat": "errors/s"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Messages per Second",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(crow_chat_messages_total[1m])",
          "legendFormat": "messages/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(crow_chat_message_errors_total[1m])",
          "legendFormat": "errors/s"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Active WebSocket Connections Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#ff6b35", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crow_socket_active_connections",
          "legendFormat": "active connections"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Request Rate by Route",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (route, method) (rate(crow_http_requests_total[1m]))",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Request Duration (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": true
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(crow_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(crow_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(crow_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Node.js — Heap Memory Usage",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#f6c90e", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "crow_nodejs_heap_size_used_bytes",
          "legendFormat": "heap used"
        },
        {
          "datasource": "Prometheus",
          "expr": "crow_nodejs_heap_size_total_bytes",
          "legendFormat": "heap total"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Node.js — Event Loop Lag",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#e84855", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(crow_nodejs_eventloop_lag_seconds_sum[1m])",
          "legendFormat": "event loop lag"
        }
      ]
    }

  ]
}
